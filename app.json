{
  "expo": {
    "name": "ConnectSphere",
    "slug": "ConnectSphere",
    "scheme": "connectsphere",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ConnectSphere membutuhkan akses lokasi untuk fitur Live Status.",
        "NSMicrophoneUsageDescription": "ConnectSphere membutuhkan akses mikrofon untuk audio note di chat."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.ryuvyyn.ConnectSphere",
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-audio",
      "expo-web-browser",
      "expo-asset",
      "@react-native-google-signin/google-signin",
      "expo-font",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": false,
          "locationWhenInUsePermission": "ConnectSphere membutuhkan akses lokasi untuk menampilkan lokasi kamu ke followers."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "44d46c21-913e-4f02-a2ad-d1e51ab09d1d"
      }
    }
  }
}
